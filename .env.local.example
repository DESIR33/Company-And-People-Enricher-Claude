# ============================================================
#  Company & People Enricher Agent — Environment Variables
# ============================================================
#
#  HOW TO USE THIS FILE:
#  1. Make a copy of this file named exactly ".env.local"
#       cp .env.local.example .env.local
#  2. Replace the placeholder values below with your real API keys.
#  3. Never commit .env.local to git — it is already in .gitignore.
#
# ============================================================


# ------------------------------------------------------------
#  ANTHROPIC API KEY  (required)
# ------------------------------------------------------------
#  Powers the AI enrichment agent (Claude).
#
#  How to get one:
#    1. Go to https://console.anthropic.com
#    2. Sign in or create a free account
#    3. Navigate to "API Keys" in the left sidebar
#    4. Click "Create Key", give it a name, and copy the key
#
#  Pricing: You are billed per token used by the agent.
#  See https://www.anthropic.com/pricing for current rates.
#  For most enrichment jobs, costs are fractions of a cent per row.
#
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ------------------------------------------------------------
#  PROSPEO API KEY  (optional — only needed for Work Email lookup)
# ------------------------------------------------------------
#  Used to find professional email addresses for people enrichment.
#  If you do not need the "Work Email" field, you can leave this blank.
#
#  How to get one:
#    1. Go to https://prospeo.io
#    2. Sign up for a free or paid plan
#    3. Navigate to your dashboard → API section
#    4. Copy your API key
#
#  Note: Without this key, the Work Email field will return empty
#  values but all other enrichment fields will still work normally.
#
PROSPEO_API_KEY=your_prospeo_api_key_here


# ------------------------------------------------------------
#  SUPABASE (optional — local/self-hosted project support)
# ------------------------------------------------------------
#  Used for Supabase integrations and future DB-backed features.
#  For a local Supabase stack, you can use:
#    SUPABASE_URL=http://localhost:8000
#    SUPABASE_PUBLISHABLE_KEY=<your local anon/publishable key>
#
#  Note: this project currently persists app data via local SQLite
#  (DATABASE_PATH). These vars enable Supabase client access.
#
# SUPABASE_URL=http://localhost:8000
# SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# SUPABASE_SQL_ENDPOINT=http://localhost:8000/pg/v1/query


# ------------------------------------------------------------
#  FIRECRAWL API KEY  (optional — boosts discovery + signals)
# ------------------------------------------------------------
#  Firecrawl pre-scrapes JS-heavy directories (Yelp, BBB, Angi,
#  Google Maps, Facebook Pages) and runs structured web searches
#  before the discovery agent runs. The agent then works from
#  clean markdown instead of hitting bot walls.
#
#  When set, the Discover page shows "Firecrawl enabled" and a
#  "Firecrawl Search" source becomes available for Google-style
#  queries with pre-scraped top results.
#
#  How to get one:
#    1. Go to https://www.firecrawl.dev
#    2. Sign up (a free tier covers small jobs)
#    3. Dashboard → API Keys → create a key
#
#  Pricing: metered per page scraped / search call. Small local
#  lead runs typically use 10–50 credits each.
#
#  When set, enricher ALSO:
#    • Uses /v1/extract (5 credits/URL) to skip the Claude agent on
#      "company" enrichment jobs whose requested fields are all
#      extractable from a single homepage URL — deterministic,
#      faster, typically cheaper than a full agent run.
#    • Uses /v1/map (1 credit/call) during directory discovery to
#      enumerate profile URLs under directory roots (chamber of
#      commerce, association member lists, YC batches, etc.), so
#      the agent iterates a known URL pool instead of hunting.
#
#  Firecrawl spend is rolled into each job/search's `costUsd` total
#  and counts against MONITOR_MONTHLY_COST_CAP. Credits are
#  converted to USD via FIRECRAWL_CREDIT_USD below (default $0.001).
#
#  Without this key, discovery still works — the agent falls back
#  to the Claude SDK's built-in WebFetch and WebSearch tools.
#
# FIRECRAWL_API_KEY=fc-your_firecrawl_api_key_here
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev   # override for self-hosted
# FIRECRAWL_CREDIT_USD=0.001                      # USD per Firecrawl credit used in cost totals


# ------------------------------------------------------------
#  GOOGLE PLACES API (New)  (optional — enables the google_places source)
# ------------------------------------------------------------
#  Native connector to Google's Places API (New) at
#  places.googleapis.com/v1. Replaces the agent-driven google_maps source
#  with deterministic JSON: faster, cheaper per lead, no LLM tokens
#  spent re-summarising structured data.
#
#  How to get one:
#    1. Go to https://console.cloud.google.com
#    2. Create or pick a project, then APIs & Services → Library
#    3. Enable "Places API (New)" — note: NOT the legacy Places API
#    4. APIs & Services → Credentials → Create credentials → API key
#    5. Restrict the key to the Places API (New) for safety
#
#  Pricing: SKU-based, billed monthly via Google Cloud. Most SMB
#  discovery calls fall under "Nearby Search Pro" or "Text Search Pro"
#  SKUs (~$0.025/req). Field mask in code requests only the fields we
#  use, keeping requests in the cheaper SKU.
#
#  Without this key, the google_places source returns an error; the
#  legacy agent-driven google_maps source still works.
#
# GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
# GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1


# ------------------------------------------------------------
#  FOURSQUARE PLACES API  (optional — enables the foursquare source)
# ------------------------------------------------------------
#  Foursquare has the broadest international SMB coverage of any
#  free-tier places API and complements Google Places well: Google
#  is freshest in the US, Foursquare picks up long-tail places and
#  international metros where Google quotas get expensive.
#
#  How to get one:
#    1. Go to https://foursquare.com/developers
#    2. Sign up, create a project, generate a "Service API key"
#    3. Auth header is the bare key (no "Bearer" prefix)
#
#  Pricing: free tier covers a generous monthly call budget; paid
#  plans for higher volume.
#
# FOURSQUARE_API_KEY=your_foursquare_service_key_here
# FOURSQUARE_BASE_URL=https://api.foursquare.com/v3


# ------------------------------------------------------------
#  BING MAPS API  (optional — enables the bing_places source)
# ------------------------------------------------------------
#  Microsoft Bing Local Search REST API. Useful as a Google Places
#  fallback in regions where Google quotas / coverage thin out, and
#  Microsoft's free tier covers moderate-volume SMB sweeps.
#
#  How to get one:
#    1. Go to https://www.bingmapsportal.com
#    2. Sign in with a Microsoft account, create a Basic key (free tier)
#    3. Copy the key
#
#  Note: Microsoft has announced retirement of Bing Maps for Enterprise
#  in favor of Azure Maps. BING_MAPS_BASE_URL exists so callers can
#  redirect to a self-hosted proxy or Azure Maps without code changes.
#
# BING_MAPS_API_KEY=your_bing_maps_api_key_here
# BING_MAPS_BASE_URL=https://dev.virtualearth.net/REST/v1


# ------------------------------------------------------------
#  TOMTOM SEARCH API  (optional — enables the tomtom source)
# ------------------------------------------------------------
#  TomTom has the strongest international POI dataset of the major
#  commercial mappers and a generous free tier (~2500 req/day).
#  Use it to fill ex-US gaps where Google Places quotas get expensive
#  and Foursquare's coverage thins out.
#
#  How to get one:
#    1. Go to https://developer.tomtom.com
#    2. Register a free account, create an app
#    3. Copy the API key
#
# TOMTOM_API_KEY=your_tomtom_api_key_here
# TOMTOM_BASE_URL=https://api.tomtom.com


# ------------------------------------------------------------
#  HERE PLACES API  (optional — enables the here_places source)
# ------------------------------------------------------------
#  HERE has best-in-class European POI coverage and detailed
#  structured addresses (vehicle-routing-grade). Pairs well with
#  Foursquare for international SMB sweeps.
#
#  How to get one:
#    1. Go to https://platform.here.com
#    2. Register a Freemium account, create a project, generate an API key
#    3. Copy the key
#
# HERE_API_KEY=your_here_api_key_here
# HERE_BASE_URL=https://discover.search.hereapi.com/v1


# ------------------------------------------------------------
#  APIFY API TOKEN  (optional — enables the apify source)
# ------------------------------------------------------------
#  Apify is a scraping-as-a-service platform with battle-tested actors
#  for the directories that block direct fetches: LinkedIn, Glassdoor,
#  Crunchbase, Yelp, Google Maps, Instagram, Indeed, Trustpilot, etc.
#  They handle proxies, browsers, anti-bot, retries, and CAPTCHA — we
#  just call the API and pay per actor run.
#
#  How to get one:
#    1. Go to https://console.apify.com
#    2. Sign up (free tier includes ~$5/mo platform credits)
#    3. Account → Integrations → Personal API tokens → create
#
#  Pricing: per actor run; varies by actor (typically $0.01-$0.10 per
#  100 results). Apify reports usage per run; we roll usageTotalUsd
#  into the search's costUsd total automatically.
#
#  Without this token, the apify source is unavailable; the agent
#  fallback uses generic web search to imitate the requested actor.
#
# APIFY_API_TOKEN=your_apify_api_token_here
# APIFY_BASE_URL=https://api.apify.com/v2


# ------------------------------------------------------------
#  SOCIAL ENGAGER — optional caps and cron secret
# ------------------------------------------------------------
#  MONITOR_MONTHLY_LEAD_CAP   — soft cap on new leads per calendar month (default 5000).
#  MONITOR_MONTHLY_COST_CAP   — soft cap on Claude spend per calendar month, USD (default 50).
#  When usage reaches 80% of either cap the UI shows a warning; at 100% new
#  scheduled/manual runs are blocked until the next month.
#
#  CRON_SECRET  — if set, GET/POST /api/cron/run-monitors requires either
#  "Authorization: Bearer $CRON_SECRET" or "?secret=$CRON_SECRET". Leave
#  unset when you're running locally; set it before exposing the endpoint.
#
# MONITOR_MONTHLY_LEAD_CAP=5000
# MONITOR_MONTHLY_COST_CAP=50
# CRON_SECRET=replace_me
